# Frontend
NEXT_PUBLIC_FASTAPI_BASE_URL=http://localhost:8000/api/v1
FASTAPI_BASE_URL=http://localhost:8000/api/v1
FASTAPI_AUTH_LOGIN_URL=
NEXT_PUBLIC_FASTAPI_AUTH_LOGIN_URL=
NEXTAUTH_SECRET=replace-me-in-development
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Backend (`apps/api/.env`)
COGNEE_API_KEY=
COGNEE_API_URL=https://api.cognee.ai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
QDRANT_API_KEY=
QDRANT_CLUSTER_ENDPOINT=
DATABASE_URL=sqlite:///./db/custom.db
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Z.ai credentials (replace with your own values; the old hardcoded token must be rotated at https://internal-api.z.ai)
ZAI_API_KEY=Z.ai
ZAI_TOKEN=
ZAI_USER_ID=
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
SCHEDULER_ENABLED=true
DEMO_USER_EMAIL=alex@summa.ai
