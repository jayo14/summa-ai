# Frontend
NEXT_PUBLIC_FASTAPI_BASE_URL=http://localhost:8000/api/v1
FASTAPI_BASE_URL=http://localhost:8000/api/v1
FASTAPI_AUTH_LOGIN_URL=
NEXT_PUBLIC_FASTAPI_AUTH_LOGIN_URL=
NEXTAUTH_SECRET=replace-me-in-development
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Backend (`apps/api/.env`)
COGNEE_API_KEY=
COGNEE_API_URL=https://api.cognee.ai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
QDRANT_API_KEY=
QDRANT_CLUSTER_ENDPOINT=
DATABASE_URL=sqlite:///./db/custom.db

# Supabase Auth
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Z.ai configuration (replace with your own values; the old hardcoded token must be rotated at https://internal-api.z.ai)
ZAI_API_KEY=Z.ai
ZAI_TOKEN=
ZAI_USER_ID=
ZAI_API_BASE=https://internal-api.z.ai/v1
ZAI_MODEL=glm-4.5
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
SCHEDULER_ENABLED=true
DEMO_USER_EMAIL=alex@summa.ai
